# ==========================================
# INTEGRAÇÃO SEFAZ - NF-e
# ==========================================

# Ambiente: 1=Produção, 2=Homologação
SEFAZ_AMBIENTE=2

# UF da empresa
SEFAZ_UF=SP

# CNPJ da empresa (sem pontos e traços)
EMPRESA_CNPJ=12345678000190

# Certificado Digital A1 (arquivo .pfx)
CERT_PATH=./certificados/certificado.pfx
CERT_PASSWORD=senha_do_certificado

# ==========================================
# OBSERVAÇÕES IMPORTANTES
# ==========================================

# 1. O certificado deve ser do tipo A1 (arquivo .pfx)
# 2. Crie uma pasta "certificados" na raiz do projeto
# 3. Coloque o arquivo .pfx dentro desta pasta
# 4. NUNCA commite o certificado no GIT
# 5. Adicione /certificados/ no .gitignore

# Como obter o certificado:
# - Compre um certificado e-CPF ou e-CNPJ tipo A1
# - Instale no computador
# - Exporte como .pfx com senha
# - Salve na pasta certificados/

# Testar em homologação primeiro!
# Ambiente 2 (homologação) permite testar sem riscos
