<%- include('includes/header') %>

<div class="container-fluid pdv-container">
    <div class="row">
        <!-- Coluna Principal -->
        <div class="col-md-8">
            <h1 class="pdv-titulo">PDV - Ponto de Venda</h1>
            
            <!-- Status Online/Offline -->
            <div class="pdv-status">
                <span id="statusIndicador" class="badge bg-success">
                    <i class="fas fa-wifi"></i> Online
                </span>
            </div>

            <!-- Busca de Produtos -->
            <div class="pdv-busca">
                <div class="input-group mb-3">
                    <input type="text" class="form-control" id="buscarProduto" 
                           placeholder="Buscar produtos...">
                    <button class="btn btn-primary" type="button" id="btnBuscar">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>

            <!-- Tabela de Itens -->
            <div class="pdv-itens">
                <table class="table table-dark table-hover">
                    <thead>
                        <tr>
                            <th>Produto</th>
                            <th>Quantidade</th>
                            <th>Valor Unit.</th>
                            <th>Total</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <!-- Totais -->
            <div class="pdv-totais">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card bg-dark text-light mb-3">
                            <div class="card-body">
                                <h5 class="card-title">Total</h5>
                                <h3 class="card-text" id="totalVenda">R$ 0,00</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-dark text-light mb-3">
                            <div class="card-body">
                                <h5 class="card-title">Itens</h5>
                                <h3 class="card-text" id="totalItens">0</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Ações -->
            <div class="pdv-acoes">
                <button type="button" class="btn btn-danger btn-lg" id="btnLimpar">
                    <i class="fas fa-trash"></i> Limpar
                </button>
                <button type="button" class="btn btn-success btn-lg" id="btnFinalizar">
                    <i class="fas fa-check"></i> Finalizar Venda
                </button>
            </div>
        </div>

        <!-- Coluna Lateral -->
        <div class="col-md-4">
            <!-- Cliente -->
            <div class="card bg-dark text-light mb-3">
                <div class="card-body">
                    <h5 class="card-title">Cliente</h5>
                    <div class="input-group">
                        <input type="text" class="form-control" id="buscarCliente" 
                               placeholder="Buscar cliente...">
                        <button class="btn btn-outline-light" type="button" id="btnBuscarCliente">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    <div id="infoCliente" class="mt-3" style="display: none;">
                        <p class="mb-1"><strong>Nome:</strong> <span id="nomeCliente"></span></p>
                        <p class="mb-1"><strong>CPF/CNPJ:</strong> <span id="documentoCliente"></span></p>
                        <p class="mb-0"><strong>Telefone:</strong> <span id="telefoneCliente"></span></p>
                    </div>
                </div>
            </div>

            <!-- Carrinho -->
            <div class="card bg-dark text-light mb-3">
                <div class="card-body">
                    <h5 class="card-title">Carrinho</h5>
                    <p class="card-text" id="totalItensCarrinho">0 itens</p>
                    <p class="card-text" id="totalCarrinho">R$ 0,00</p>
                </div>
            </div>

            <!-- Sincronização -->
            <div class="card bg-dark text-light">
                <div class="card-body">
                    <h5 class="card-title">Status</h5>
                    <p class="card-text" id="statusSinc">
                        <i class="fas fa-sync-alt"></i> Sincronizado
                    </p>
                    <p class="card-text" id="vendasPendentes">
                        0 vendas pendentes
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Pagamento -->
<div class="modal fade" id="modalPagamento" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title">Finalizar Venda</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Formas de Pagamento -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Forma de Pagamento</label>
                        <select class="form-select" id="formaPagamento">
                            <option value="DINHEIRO">Dinheiro</option>
                            <option value="PIX">PIX</option>
                            <option value="CARTAO_DEBITO">Cartão de Débito</option>
                            <option value="CARTAO_CREDITO">Cartão de Crédito</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Parcelas</label>
                        <select class="form-select" id="parcelas" disabled>
                            <option value="1">À Vista</option>
                        </select>
                    </div>
                </div>

                <!-- Valores -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Total</label>
                        <input type="text" class="form-control" id="totalPagamento" readonly>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Valor Pago</label>
                        <input type="number" class="form-control" id="valorPago" step="0.01">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Troco</label>
                        <input type="text" class="form-control" id="troco" readonly>
                    </div>
                </div>

                <!-- Opções Fiscais -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="emitirNFCe">
                            <label class="form-check-label" for="emitirNFCe">
                                Emitir NFCe
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnConfirmarPagamento">
                    Confirmar Pagamento
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="/js/pdv.js"></script>
<script src="/js/pdv-operacoes.js"></script>

<!-- Estilos -->
<link rel="stylesheet" href="/css/pdv.css">
<link rel="stylesheet" href="/css/pdv-operacoes.css">

<%- include('includes/footer') %>